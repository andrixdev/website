RewriteEngine On

# 1. Force the empty root URL to load the SPA index file
RewriteRule ^$ website/index.html [L]

# 2. Allow existing files and directories (except the root itself) to load normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. If it's not a valid resource, rewrite to the website subfolder
RewriteCond %{REQUEST_URI} !^/website/
RewriteRule ^(.*)$ website/$1 [L]